{
  "arch": "x86_64",
  "cpu": "x86-64",
  "data-layout": "e-m:e-p270:32:32-p271:32:32-p272:64:64-f64:64:64-f80:128-n8:16:32:64-S128",
  "disable-redzone": true,
  "dynamic-linking": false,
  "eh-frame-header": false,
  "executables": true,
  "linker-flavor": "gnu-lld",
  "linker": "rust-lld",
  "llvm-target": "x86_64-unknown-none",
  "max-atomic-width": 64,
  "metadata": {
    "description": "HXNU x86_64 freestanding target"
  },
  "panic-strategy": "abort",
  "position-independent-executables": false,
  "relro-level": "off",
  "target-endian": "little",
  "target-pointer-width": "64",
  "vendor": "hxnu"
}
